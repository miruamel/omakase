{
  "name": "omakase",
  "version": "0.1.0",
  "type": "module",
  "license": "Apache-2.0",
  "main": "src/entrypoints/cli.tsx",
  "bin": {
    "omakase": "./src/entrypoints/cli.tsx"
  },
  "scripts": {
    "start": "bun run src/entrypoints/cli.tsx",
    "dev": "bun run --watch src/entrypoints/cli.tsx",
    "build": "bun build src/entrypoints/cli.tsx --outdir ./dist --target node --banner '#!/usr/bin/env node'",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "format": "./scripts/format.sh",
    "lint": "./scripts/lint.sh",
    "validate": "./scripts/validate-resilience.sh",
    "stats": "./scripts/show-stats.sh",
    "release": "./scripts/release.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "glob": "^13.0.6",
    "ink": "^7.1.0",
    "openai": "^6.45.0",
    "react": "^19.2.7",
    "react-devtools-core": "^7.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "typescript": "5.9.3"
  },
  "keywords": ["ai", "cli", "coding-assistant", "llm", "multi-agent", "automation"],
  "author": "miruamel",
  "repository": "github:miruamel/omakase",
  "engines": {"bun": ">=1.0.0"}
}
